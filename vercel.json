{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "main.js",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/privacy-policy",
      "dest": "privacy-policy.html"
    },
    {
      "src": "/terms-of-service",
      "dest": "terms-of-service.html"
    },
    {
      "src": "/refund-policy",
      "dest": "refund-policy.html"
    },
    {
      "src": "/disclaimer",
      "dest": "disclaimer.html"
    },
    {
      "src": "/contact",
      "dest": "contact.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
